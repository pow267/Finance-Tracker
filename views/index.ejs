<!DOCTYPE html>
<html lang="vi">
    
<head>
    <meta charset="UTF-8">
    <title>Finance Tracker - IT Lead Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        :root { --primary: #4e73df; --success: #1cc88a; --danger: #e74a3b; }
        body { background-color: #f8f9fc; font-family: 'Segoe UI', sans-serif; display: flex; flex-direction: column; min-height: 100vh; }
        .card { border: none; border-radius: 12px; box-shadow: 0 0.15rem 1.75rem 0 rgba(58, 59, 69, 0.1); }
        .chart-container { position: relative; height: 200px; width: 100%; }
        .year-nav { display: flex; justify-content: center; align-items: center; gap: 15px; margin-bottom: 10px; }
        .nav-btn { cursor: pointer; user-select: none; font-weight: bold; color: var(--primary); font-size: 1.2rem; }
        .nav-btn:hover { color: #2e59d9; }
        .footer { background: #fff; padding: 20px 0; border-top: 1px solid #e3e6f0; text-align: center; color: #858796; font-size: 0.9rem; margin-top: auto; }
    </style>
</head>
<body>

<div class="container py-4 content">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark">📊 Quản Lý Tài Chính</h2>
        <div class="badge bg-primary p-2 shadow-sm" style="cursor: pointer;" onclick="updateBudget()">
            Hạn mức: <%= budgetLimit.toLocaleString() %>đ ✏️
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card p-4 shadow-sm mb-4">
                <form action="/add" method="POST">
                    <input type="date" name="date" id="dateIn" class="form-control mb-2" required>
                    <input type="text" name="title" class="form-control mb-2" placeholder="Nội dung..." required>
                    <input type="number" name="amount" class="form-control mb-2" placeholder="Số tiền" required>
                    <select name="category" class="form-select mb-2">
                        <option value="Ăn uống">Ăn uống</option><option value="Đi lại">Đi lại</option><option value="Tiền lương">Tiền lương</option><option value="Dự án">Dự án</option><option value="Tiền trọ">Tiền trọ</option>
                    </select>
                    <select name="type" class="form-select mb-3">
                        <option value="expense">Chi (-)</option><option value="income">Thu (+)</option>
                    </select>
                    <button class="btn btn-primary w-100 fw-bold">GHI LẠI</button>
                </form>
            </div>
            <div class="card p-3 shadow-sm"><canvas id="catChart" style="height: 250px;"></canvas></div>
        </div>

        <div class="col-lg-8">
            <div class="card p-3 shadow-sm mb-4">
                <div class="year-nav">
                    <span class="nav-btn" onclick="changeYear(-1)">«</span>
                    <h6 class="fw-bold m-0" id="expTitle">CHI TIÊU NĂM <%= selectedYear %></h6>
                    <span class="nav-btn" onclick="changeYear(1)">»</span>
                </div>
                <div class="chart-container"><canvas id="expTrend"></canvas></div>
            </div>

            <div class="card p-3 shadow-sm mb-4 border-bottom-success">
                <div class="year-nav">
                    <span class="nav-btn" onclick="changeYear(-1)">«</span>
                    <h6 class="fw-bold m-0" id="incTitle">THU NHẬP NĂM <%= selectedYear %></h6>
                    <span class="nav-btn" onclick="changeYear(1)">»</span>
                </div>
                <div class="chart-container"><canvas id="incTrend"></canvas></div>
            </div>
            
            <div class="card shadow-sm p-3">
                <div class="d-flex justify-content-between mb-3 border-bottom pb-2">
                    <h6 class="fw-bold text-primary m-0">📝 Chi tiết tháng</h6>
                    <select id="mFilter" class="form-select form-select-sm w-auto" onchange="filter()"></select>
                </div>
                <div class="row g-2 mb-3 text-center fw-bold small">
                    <div class="col-4 border-end">THU: <span id="sInc" class="text-success">0đ</span></div>
                    <div class="col-4 border-end">CHI: <span id="sExp" class="text-danger">0đ</span></div>
                    <div class="col-4">DƯ: <span id="sBal" class="text-primary">0đ</span></div>
                </div>
                <div class="table-responsive" style="max-height: 300px;">
                    <table class="table table-sm table-hover align-middle"><tbody id="tBody"></tbody></table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="eModal" tabindex="-1">
    <div class="modal-dialog"><form id="eForm" method="POST"><div class="modal-content"><div class="modal-body p-4">
        <input type="text" name="title" id="eT" class="form-control mb-2" required>
        <input type="number" name="amount" id="eA" class="form-control mb-2" required>
        <select name="category" id="eC" class="form-select mb-3">
            <option value="Ăn uống">Ăn uống</option><option value="Đi lại">Đi lại</option><option value="Tiền lương">Tiền lương</option><option value="Dự án">Dự án</option><option value="Tiền trọ">Tiền trọ</option>
        </select>
        <select name="type" id="eTy" class="form-select mb-3">
            <option value="expense">Chi (-)</option><option value="income">Thu (+)</option>
        </select>
        <button type="submit" class="btn btn-primary w-100 fw-bold">CẬP NHẬT</button>
    </div></div></form></div>
</div>

<footer class="footer">
    Copyright © 2026 <strong>Nguyễn Trình Khánh Văn</strong>. All rights reserved.
</footer>

<script>
    const SERVER_YEAR = <%= selectedYear %>;
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
    let allData = [];
    let currentYear = SERVER_YEAR;
    let expChart, incChart, catChart;
    const editModal = new bootstrap.Modal(document.getElementById('eModal'));
    document.getElementById('dateIn').valueAsDate = new Date();

    async function init() {
        const res = await fetch('/api/chart-data');
        allData = await res.json();
        setupFilters();
        drawAll();
        filter();
    }

    function changeYear(step) {
        currentYear += step;
        document.getElementById('expTitle').innerText = `CHI TIÊU NĂM ${currentYear}`;
        document.getElementById('incTitle').innerText = `THU NHẬP NĂM ${currentYear}`;
        drawAll();
    }

    function drawAll() {
        const labels = ["T1","T2","T3","T4","T5","T6","T7","T8","T9","T10","T11","T12"];
        const expData = new Array(12).fill(0);
        const incData = new Array(12).fill(0);

        allData.forEach(d => {
            const dt = new Date(d.date);
            if (dt.getFullYear() === currentYear) {
                if (d.type === 'expense') expData[dt.getMonth()] += d.amount;
                else incData[dt.getMonth()] += d.amount;
            }
        });

        if (expChart) expChart.destroy();
        if (incChart) incChart.destroy();
        if (catChart) catChart.destroy();

        const commonOpt = { maintainAspectRatio: false, responsive: true, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true } } };

        expChart = new Chart(document.getElementById('expTrend'), {
            type: 'bar',
            data: { labels, datasets: [{ label: 'Chi tiêu', data: expData, backgroundColor: '#e74a3b' }] },
            options: commonOpt
        });

        incChart = new Chart(document.getElementById('incTrend'), {
            type: 'bar',
            data: { labels, datasets: [{ label: 'Thu nhập', data: incData, backgroundColor: '#1cc88a' }] },
            options: commonOpt
        });

        const cats = {};
        allData.filter(d => d.type === 'expense')
               .forEach(d => cats[d.category] = (cats[d.category] || 0) + d.amount);

        catChart = new Chart(document.getElementById('catChart'), {
            type: 'doughnut',
            data: {
                labels: Object.keys(cats),
                datasets: [{
                    data: Object.values(cats),
                    backgroundColor: ['#4e73df', '#1cc88a', '#f6c23e', '#e74a3b', '#36a2eb']
                }]
            },
            options: { maintainAspectRatio: false, plugins: { title: { display: true, text: 'CƠ CẤU CHI TIÊU TỔNG' } } }
        });
    }

    function setupFilters() {
        const ms = [...new Set(allData.map(t => {
            const d = new Date(t.date);
            return `${d.getMonth()+1}/${d.getFullYear()}`;
        }))].sort((a,b) => b.localeCompare(a));

        document.getElementById('mFilter').innerHTML =
            ms.map(m => `<option value="${m}">Tháng ${m}</option>`).join('') +
            '<option value="all">Tất cả</option>';
    }

    function filter() {
        const sel = document.getElementById('mFilter').value;
        const b = document.getElementById('tBody');
        let i = 0, e = 0;
        b.innerHTML = '';

        allData.forEach(t => {
            const d = new Date(t.date);
            if (sel === 'all' || `${d.getMonth()+1}/${d.getFullYear()}` === sel) {
                if (t.type === 'income') i += t.amount; else e += t.amount;
                b.innerHTML += `<tr>
                    <td>${d.toLocaleDateString('vi-VN')}</td>
                    <td><strong>${t.title}</strong></td>
                    <td class="text-end fw-bold ${t.type === 'income' ? 'text-success' : 'text-danger'}">${t.amount.toLocaleString()}đ</td>
                    <td class="text-center">
                        <span style="cursor:pointer" onclick='openE(${JSON.stringify(t)})'>✏️</span>
                        <form action="/delete/${t._id}" method="POST" style="display:inline"><button class="btn btn-sm">❌</button></form>
                    </td>
                </tr>`;
            }
        });

        document.getElementById('sInc').innerText = i.toLocaleString() + 'đ';
        document.getElementById('sExp').innerText = e.toLocaleString() + 'đ';
        document.getElementById('sBal').innerText = (i - e).toLocaleString() + 'đ';
    }

    function openE(t) {
        document.getElementById('eForm').action = `/edit/${t._id}`;
        document.getElementById('eT').value = t.title;
        document.getElementById('eA').value = t.amount;
        document.getElementById('eC').value = t.category;
        document.getElementById('eTy').value = t.type;
        editModal.show();
    }

    async function updateBudget() {
        const n = prompt("Hạn mức mới:", "10000000");
        if (n) {
            await fetch('/update-budget', {
                method:'POST',
                headers:{'Content-Type':'application/json'},
                body:JSON.stringify({newLimit:parseInt(n)})
            });
            location.reload();
        }
    }

    init();
</script>
</body>
</html>